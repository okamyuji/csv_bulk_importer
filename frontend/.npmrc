; Supply-chain hardening: refuse any package version released in the last 7 days (10080 minutes).
; https://pnpm.io/settings#minimumreleaseage
minimum-release-age=10080

; Fail install if a transitive dep was published inside the window.
minimum-release-age-exclude=

; Always install the pinned lockfile; fail if it would change on CI.
frozen-lockfile=true

; Reject postinstall scripts for dependencies except a small allowlist (add pkgs here as needed).
ignore-scripts=true
